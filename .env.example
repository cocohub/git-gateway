# Version Control Agent Gateway - Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is automatically loaded on startup.

# =============================================================================
# Upstream Git Provider Tokens
# =============================================================================

# GitHub personal access token or GitHub App token
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab personal access token (optional)
# Required scopes: api, read_repository, write_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Bitbucket app password (optional)
# Create at: https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Agent API Keys
# =============================================================================
# Generate secure random keys for each agent, e.g.:
#   openssl rand -hex 32

# Code generation agent
AGENT_CODEGEN_KEY=your-secure-api-key-for-codegen-agent

# Code review agent (read-only)
AGENT_REVIEWER_KEY=your-secure-api-key-for-reviewer-agent

# Deployment agent
AGENT_DEPLOYER_KEY=your-secure-api-key-for-deployer-agent
